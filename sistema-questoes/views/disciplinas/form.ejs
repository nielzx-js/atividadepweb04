<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Disciplina</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: Arial, sans-serif;
    background: #f0f0f0;
    display: flex;
    min-height: 100vh;
  }

  .sidebar {
    width: 130px;
    background: #111111;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    flex-shrink: 0;
  }

  .sidebar .logo {
    padding: 16px 14px 20px 14px;
    font-size: 1.15rem;
    font-weight: 700;
    color: #fff;
  }

  .sidebar .logo span { color: #f5c400; }

  .sidebar nav { display: flex; flex-direction: column; }

  .sidebar nav a {
    color: #ffffff;
    text-decoration: none;
    font-size: 0.9rem;
    padding: 10px 14px;
    transition: background 0.2s;
  }

  .sidebar nav a:hover { background: #222; }

  .main {
    flex: 1;
    padding: 30px;
    background: #f0f0f0;
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  .container {
    background: #fff;
    padding: 28px 30px;
    border-radius: 6px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    width: 400px;
  }

  h2 {
    font-size: 1.2rem;
    color: #333;
    margin-bottom: 20px;
    border-left: 4px solid #f5c400;
    padding-left: 10px;
  }

  label {
    display: block;
    margin-top: 14px;
    font-size: 0.85rem;
    color: #555;
    font-weight: 600;
  }

  input {
    width: 100%;
    padding: 8px 10px;
    margin-top: 4px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 0.9rem;
    background: #fafafa;
    transition: border 0.2s;
  }

  input:focus {
    outline: none;
    border-color: #f5c400;
    background: #fff;
  }

  .botoes {
    margin-top: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  button {
    padding: 9px 20px;
    background: #111111;
    color: #fff;
    border: none;
    border-radius: 4px;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.2s;
  }

  button:hover { background: #f5c400; color: #111; }

  .cancelar {
    font-size: 0.9rem;
    color: #888;
    text-decoration: none;
    transition: color 0.2s;
  }

  .cancelar:hover { color: #333; text-decoration: underline; }
</style>
</head>

<body>

  <aside class="sidebar">
    <div class="logo"><span>e</span>Sistema</div>
    <nav>
      <a href="/principal">Home</a>
      <a href="/disciplinas">Disciplinas</a>
      <a href="/questoes">Questões</a>
        <a href="/usuarios">Usuários</a>
      <a href="/logout">Sair</a>
    </nav>
  </aside>

  <main class="main">
    <div class="container">
      <h2><%= disciplina ? 'Editar' : 'Nova' %> Disciplina</h2>

      <form method="POST" action="/disciplinas/<%= disciplina ? 'editar/' + disciplina.id : 'nova' %>">

        <label>Nome:</label>
        <input type="text" name="nome" value="<%= disciplina ? disciplina.nome : '' %>" required>

        <label>Carga Horária:</label>
        <input type="number" name="carga_horaria" value="<%= disciplina ? disciplina.carga_horaria : '' %>" required>

        <div class="botoes">
          <button type="submit">Salvar</button>
          <a class="cancelar" href="/disciplinas">Cancelar</a>
        </div>

      </form>
    </div>
  </main>

</body>
</html>