<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Disciplinas</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: Arial, sans-serif;
    background: #f0f0f0;
    display: flex;
    min-height: 100vh;
  }

  .sidebar {
    width: 130px;
    background: #111111;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    flex-shrink: 0;
  }

  .sidebar .logo {
    padding: 16px 14px 20px 14px;
    font-size: 1.15rem;
    font-weight: 700;
    color: #fff;
  }

  .sidebar .logo span { color: #f5c400; }

  .sidebar nav { display: flex; flex-direction: column; }

  .sidebar nav a {
    color: #ffffff;
    text-decoration: none;
    font-size: 0.9rem;
    padding: 10px 14px;
    transition: background 0.2s;
  }

  .sidebar nav a:hover { background: #222; }

  .main {
    flex: 1;
    padding: 30px;
    background: #f0f0f0;
  }

  .container {
    background: #fff;
    padding: 28px 30px;
    border-radius: 6px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }

  h2 {
    font-size: 1.2rem;
    color: #333;
    margin-bottom: 20px;
    border-left: 4px solid #f5c400;
    padding-left: 10px;
  }

  .novo {
    display: inline-block;
    margin-bottom: 16px;
    padding: 8px 16px;
    background: #111111;
    color: #fff;
    text-decoration: none;
    border-radius: 4px;
    font-size: 0.85rem;
    transition: background 0.2s;
  }

  .novo:hover { background: #f5c400; color: #111; }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  th, td {
    border: 1px solid #e0e0e0;
    padding: 10px 12px;
    text-align: center;
  }

  th {
    background: #111111;
    color: #fff;
    font-weight: 600;
  }

  tr:nth-child(even) { background: #fafafa; }
  tr:hover { background: #fff8e1; }

  td a {
    text-decoration: none;
    font-size: 0.85rem;
    color: #555;
    transition: color 0.2s;
  }

  td a:hover { color: #111; text-decoration: underline; }

  td a.deletar { color: #c0392b; }
  td a.deletar:hover { color: #922b21; }
</style>
</head>

<body>

  <aside class="sidebar">
    <div class="logo"><span>e</span>Sistema</div>
    <nav>
      <a href="/principal">Home</a>
      <a href="/disciplinas">Disciplinas</a>
      <a href="/questoes">Questões</a>
        <a href="/usuarios">Usuários</a>
      <a href="/logout">Sair</a>
    </nav>
  </aside>

  <main class="main">
    <div class="container">
      <h2>Disciplinas</h2>

      <a class="novo" href="/disciplinas/nova">+ Nova Disciplina</a>

      <table>
        <tr>
          <th>ID</th>
          <th>Nome</th>
          <th>Carga Horária</th>
          <th>Ações</th>
        </tr>

        <% disciplinas.forEach(d => { %>
        <tr>
          <td><%= d.id %></td>
          <td><%= d.nome %></td>
          <td><%= d.carga_horaria %>h</td>
          <td>
            <a href="/disciplinas/editar/<%= d.id %>">Editar</a> |
            <a class="deletar" href="/disciplinas/deletar/<%= d.id %>" onclick="return confirm('Deletar?')">Deletar</a>
          </td>
        </tr>
        <% }) %>
      </table>
    </div>
  </main>

</body>
</html>