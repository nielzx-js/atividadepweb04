<!DOCTYPE html>
<html lang="pt-br">
<head><meta charset="UTF-8"><title>Questões</title></head>
<body>
  <h2>Questões</h2>
  <nav><a href="/">Home</a> | <a href="/disciplinas">Disciplinas</a> | <a href="/logout">Sair</a></nav>
  <hr>
  <a href="/questoes/nova">+ Nova Questão</a>
  <br><br>
  <table border="1" cellpadding="5">
    <tr>
      <th>ID</th><th>Enunciado</th><th>Correta</th><th>Disciplina</th><th>Ações</th>
    </tr>
    <% questoes.forEach(q => { %>
    <tr>
      <td><%= q.id %></td>
      <td><%= q.enunciado.substring(0, 60) %>...</td>
      <td><%= q.correta.toUpperCase() %></td>
      <td><%= q.disciplina || '-' %></td>
      <td>
        <a href="/questoes/editar/<%= q.id %>">Editar</a> |
        <a href="/questoes/deletar/<%= q.id %>" onclick="return confirm('Deletar?')">Deletar</a>
      </td>
    </tr>
    <% }) %>
  </table>
</body>
</html>
